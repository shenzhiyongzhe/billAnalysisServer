generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WechatUser {
  id        Int      @id @default(autoincrement())
  openid    String   @unique
  displayId String   @unique 
  nickname         String   @default("微信用户")
  avatar           String   @default("/static/default-avatar.png")
  remainingQueries Int      @default(500)
  totalQueries     Int      @default(0)
  shareCount       Int      @default(0)
  level            Int      @default(1)
  monthlyCardExpiry DateTime? // 月卡到期时间，null 表示无月卡
  records          QueryRecord[]
  session          UserSession?
  shareRecords     ShareRecord[] @relation("SharerRelation")
  openRecords      ShareRecord[] @relation("OpenerRelation")
  createdAt        DateTime @default(now())
  queryOperationLogs QueryOperationRecord[] @relation("TargetUserRelation")
  adminOperationLogs QueryOperationRecord[] @relation("AdminUserRelation")
  customCategories   UserCustomCategory[]
}

model ShareRecord {
  id        Int      @id @default(autoincrement())
  sharerId  Int
  sharer    WechatUser @relation("SharerRelation", fields: [sharerId], references: [id], onDelete: Cascade)
  openerId  Int?
  opener    WechatUser? @relation("OpenerRelation", fields: [openerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model UserSession {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             WechatUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  updatedAt        DateTime @updatedAt
}

model StatementUser {
  id          Int      @id @default(autoincrement())
  name        String
  idNumber    String?  @unique
  cardNumber  String?  @unique
  phoneNumber String?
  queryCount  Int      @default(1)
  records     QueryRecord[]
  createdAt   DateTime @default(now())
}

model QueryRecord {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            WechatUser @relation(fields: [userId], references: [id])
  statementUserId Int?
  statementUser   StatementUser? @relation(fields: [statementUserId], references: [id])
  filePath        String   
  source          String   
  status          String   @default("pending")
  summaryJson     Json?
  transactionsJson Json?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
}

model SystemConfig {
  key   String @id
  value String
}

model QueryOperationRecord {
  id            Int        @id @default(autoincrement())
  userId        Int
  user          WechatUser @relation("TargetUserRelation", fields: [userId], references: [id], onDelete: Cascade)
  adminId       Int?
  admin         WechatUser? @relation("AdminUserRelation", fields: [adminId], references: [id], onDelete: SetNull)
  operationType String     @default("queries") // "queries" | "monthly_card"
  oldQueries    Int
  newQueries    Int
  changeAmount  Int
  reason        String?    @default("管理员修改")
  createdAt     DateTime   @default(now())
}

model DailyStatistics {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  todayQueries   Int      @default(0)
  todayRecharges Int      @default(0)
  totalQueries   Int      @default(0)
  totalRecharges Int      @default(0)
  avgQueriesPerDay Float  @default(0)
  createdAt      DateTime @default(now())
}

model GlobalCategoryKeyword {
  id        Int      @id @default(autoincrement())
  category  String   // e.g. "餐饮", "购物", "交通", "娱乐", "服务", "转账", "收入"
  keyword   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCustomCategory {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         WechatUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  counterparty String     // 交易对方名称，精确匹配
  category     String     // e.g. "餐饮", "购物", "交通", "娱乐", "服务", "转账", "收入", "其他"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, counterparty])
}

