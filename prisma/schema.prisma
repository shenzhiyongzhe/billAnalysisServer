generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WechatUser {
  id        Int      @id @default(autoincrement())
  openid    String   @unique
  displayId String   @unique 
  nickname         String   @default("微信用户")
  avatar           String   @default("/static/default-avatar.png")
  remainingQueries Int      @default(99)
  level            Int      @default(1)
  records          QueryRecord[]
  session          UserSession?
  createdAt        DateTime @default(now())
}

model UserSession {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             WechatUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  updatedAt        DateTime @updatedAt
}

model StatementUser {
  id         Int      @id @default(autoincrement())
  name       String
  idNumber   String?  @unique
  cardNumber String?  @unique
  queryCount Int      @default(1)
  records    QueryRecord[]
  createdAt  DateTime @default(now())
}

model QueryRecord {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            WechatUser @relation(fields: [userId], references: [id])
  statementUserId Int?
  statementUser   StatementUser? @relation(fields: [statementUserId], references: [id])
  filePath        String   
  source          String   
  status          String   @default("pending")
  summaryJson     Json?
  transactionsJson Json?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
}
