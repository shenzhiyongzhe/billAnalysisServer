# 复制为 .env（本地与服务器部署目录均需，勿提交 .env）
PORT=4000
API_PREFIX=api/bill-analysis
DATABASE_URL=postgresql://admin:你的强密码@postgres-server:5432/bill_analysis?schema=public
WX_APP_ID=
WX_APP_SECRET=
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d
SHARE_CODE_SECRET=change-me-to-a-different-long-random-string

# AI 风控分析配置（OpenAI 兼容接口）
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your-api-key-here
AI_MODEL=qwen-plus
